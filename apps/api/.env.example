DATABASE_URL="postgresql://username:password@localhost:5432/Nutrio"

# ========================================================================
# CORS
# ========================================================================
# Comma-separated list of allowed origins. Leave unset to allow all (local dev).
# Example: ALLOWED_ORIGINS=https://app.domain.com,https://pwa.domain.com
# ALLOWED_ORIGINS=
JWT_ACCESS_SECRET="your-access-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
REDIS_URL="redis://localhost:6379"

# Access Control
# Set to 'true' to use database-driven permissions (requires seeded data)
# Set to 'false' to use hardcoded permissions (fallback)
USE_DB_PERMISSIONS=false

# Cache Configuration
CACHE_TTL=300

# ========================================================================
# Database Role Configuration (for migrations)
# ========================================================================
# Set SKIP_DB_ROLES=true for cloud databases (e.g., Supabase, Neon, RDS)
# that don't allow CREATE ROLE. This will skip role creation, RLS role
# policies, and GRANT statements during migration.
SKIP_DB_ROLES=false

# Custom database role names (defaults shown below)
# DB_ROLE_OWNER=postgres
# DB_ROLE_ADMIN=Nutrio_admin
# DB_ROLE_APP=Nutrio_app
# DB_ROLE_READONLY=Nutrio_readonly

# Database role passwords (only used when SKIP_DB_ROLES=false)
# DB_ROLE_ADMIN_PASSWORD=your-admin-password
# DB_ROLE_APP_PASSWORD=your-app-password
# DB_ROLE_READONLY_PASSWORD=your-readonly-password

# ========================================================================
# Seed Configuration
# ========================================================================
# Default admin password for seeded users (defaults: role-specific like Admin123!)
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_DEFAULT_PASSWORD=Default123!

# ========================================================================
# AI/LLM Integration
# ========================================================================
AI_PROVIDER=anthropic
AI_API_KEY=your-api-key-here
AI_MODEL=claude-sonnet-4-6
AI_MOCK=true

# ========================================================================
# File Storage (MinIO / S3-compatible)
# ========================================================================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nutrio-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1