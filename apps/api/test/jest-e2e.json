{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@workspace/common$": "<rootDir>/../../packages/common/src/index.ts",
    "^@workspace/common/(.*)$": "<rootDir>/../../packages/common/src/$1"
  }
}
